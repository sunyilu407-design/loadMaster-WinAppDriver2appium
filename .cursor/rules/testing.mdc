### 8.3 Menu Navigation (main_handler Pattern)

```python
# Define navigation method in main_handler
def navigate_to_user_management(self):
    """Navigate to user management page"""
    if not self.main_page.is_main_page_present():
        raise Exception("Not on main page")
    
    # Click parent menu
    self.main_page.click_user_management_parent_menu()
    time.sleep(0.5)  # Wait for submenu to expand
    
    # Click child menu
    self.main_page.click_user_management_child_menu()
    
    self.log.info("Successfully navigated to user management page")
    return True

# Call from other handlers
self.main_handler.navigate_to_user_management()
```

### 8.4 Dialog Confirm/Cancel Pattern

```python
def delete_user_and_verify(self, username, confirm=True):
    """Delete user and verify"""
    # Click delete button
    self.page.click_delete_button()
    
    # Handle confirmation dialog
    action = 'confirm' if confirm else 'cancel'
    self.handle_operation_prompt(action=action)
    
    # Verify result
    expected = 'absent' if confirm else 'present'
    return self.verify_user_in_table({'姓名': username}, expected_presence=expected)
```

